{
	"name": "Apartment Management (Java Spring Boot)",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "21-bullseye"
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/maven:1": {
			"version": "latest"
		}
	},
	"forwardPorts": [8080],
	"customizations": {
		"vscode": {
			"extensions": [
				"vscjava.vscode-java-pack",
				"vscjava.vscode-spring-initializr",
				"vscjava.vscode-spring-boot-dashboard",
				"vmware.vscode-spring-boot"
			]
		}
	},
	"postCreateCommand": "chmod +x mvnw && ./mvnw clean install -DskipTests"
}
